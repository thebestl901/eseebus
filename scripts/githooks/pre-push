#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
FIX_SCRIPT="$ROOT/scripts/git-ensure-author.sh"
OLD_NAME="KC Y"

if [ ! -x "$FIX_SCRIPT" ]; then
  echo "pre-push: missing $FIX_SCRIPT" >&2
  exit 1
fi

rewrote=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if "$FIX_SCRIPT" --check-range "$range"; then
    echo "pre-push: found $OLD_NAME commits on $local_ref, rewriting before push..."
    "$FIX_SCRIPT" --ref "$local_ref"
    rewrote=1
  fi
done

if [ "$rewrote" -eq 1 ]; then
  echo "pre-push: author rewritten to TheBestopq. Continue pushing updated commits."
fi

exit 0
