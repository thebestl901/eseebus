{
  "name": "eseebus",
  "private": true,
  "version": "1.2.0",
  "author": "TheBestopq",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "docker:build": "docker build -t eseebus .",
    "docker:up": "docker compose up -d --build eseebus",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f eseebus",
    "docker:restart": "docker compose up -d --build eseebus",
    "docker:staging:up": "docker compose up -d --build eseebus-staging",
    "docker:staging:down": "docker compose stop eseebus-staging",
    "docker:staging:logs": "docker compose logs -f eseebus-staging",
    "docker:staging:restart": "docker compose up -d --build eseebus-staging"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
