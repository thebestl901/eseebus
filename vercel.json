{
  "rewrites": [
    { "source": "/api/kmb/:path*", "destination": "https://data.etabus.gov.hk/v1/transport/kmb/:path*" },
    { "source": "/api/citybus/:path*", "destination": "https://rt.data.gov.hk/v2/transport/citybus/:path*" },
    { "source": "/api/gmb/:path*", "destination": "https://data.etagmb.gov.hk/:path*" },
    { "source": "/api/hko/:path*", "destination": "https://data.weather.gov.hk/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
